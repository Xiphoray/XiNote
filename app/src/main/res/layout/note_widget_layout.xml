<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- Dynamically colored background with rounded corners -->
    <ImageView
        android:id="@+id/widget_background_view"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="fitXY"
        android:src="@drawable/widget_background" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Widget Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/widget_title"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="XiNote"
                android:textColor="#1F1B1A"
                android:textSize="16sp"
                android:textStyle="bold"
                android:letterSpacing="0.02" />

            <ImageView
                android:id="@+id/btn_add_note"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:contentDescription="新增记事"
                android:padding="6dp"
                android:scaleType="fitCenter"
                android:src="@drawable/ic_add" />
        </LinearLayout>

        <!-- Main Divider under Header -->
        <FrameLayout
            android:id="@+id/widget_divider"
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="8dp"
            android:background="#E5DED8" />

        <!-- Empty State View -->
        <TextView
            android:id="@+id/widget_empty_text"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:text="暂无内容，点击上方 + 新增"
            android:textColor="#857370"
            android:textSize="13sp"
            android:visibility="gone" />

        <!-- Notes List Container -->
        <LinearLayout
            android:id="@+id/notes_container"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical">

            <!-- Slot 1 -->
            <LinearLayout
                android:id="@+id/note_slot_1"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingTop="6dp"
                android:paddingBottom="6dp"
                android:paddingLeft="2dp"
                android:paddingRight="2dp">

                <!-- Left Rounded Accent Color Bar -->
                <ImageView
                    android:id="@+id/note_color_bar_1"
                    android:layout_width="4dp"
                    android:layout_height="32dp"
                    android:scaleType="fitXY"
                    android:src="@drawable/widget_color_bar" />

                <!-- Text Info -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="10dp"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/note_title_1"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:ellipsize="end"
                        android:maxLines="1"
                        android:textColor="#1F1B1A"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/note_content_1"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:ellipsize="end"
                        android:maxLines="1"
                        android:textColor="#4E4442"
                        android:textSize="12sp" />
                </LinearLayout>
            </LinearLayout>

            <FrameLayout
                android:id="@+id/note_divider_1"
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginTop="2dp"
                android:layout_marginBottom="2dp"
                android:background="#F5DED8" />

            <!-- Slot 2 -->
            <LinearLayout
                android:id="@+id/note_slot_2"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingTop="6dp"
                android:paddingBottom="6dp"
                android:paddingLeft="2dp"
                android:paddingRight="2dp">

                <!-- Left Rounded Accent Color Bar -->
                <ImageView
                    android:id="@+id/note_color_bar_2"
                    android:layout_width="4dp"
                    android:layout_height="32dp"
                    android:scaleType="fitXY"
                    android:src="@drawable/widget_color_bar" />

                <!-- Text Info -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="10dp"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/note_title_2"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:ellipsize="end"
                        android:maxLines="1"
                        android:textColor="#1F1B1A"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/note_content_2"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:ellipsize="end"
                        android:maxLines="1"
                        android:textColor="#4E4442"
                        android:textSize="12sp" />
                </LinearLayout>
            </LinearLayout>

            <FrameLayout
                android:id="@+id/note_divider_2"
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginTop="2dp"
                android:layout_marginBottom="2dp"
                android:background="#F5DED8" />

            <!-- Slot 3 -->
            <LinearLayout
                android:id="@+id/note_slot_3"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingTop="6dp"
                android:paddingBottom="6dp"
                android:paddingLeft="2dp"
                android:paddingRight="2dp">

                <!-- Left Rounded Accent Color Bar -->
                <ImageView
                    android:id="@+id/note_color_bar_3"
                    android:layout_width="4dp"
                    android:layout_height="32dp"
                    android:scaleType="fitXY"
                    android:src="@drawable/widget_color_bar" />

                <!-- Text Info -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="10dp"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/note_title_3"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:ellipsize="end"
                        android:maxLines="1"
                        android:textColor="#1F1B1A"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/note_content_3"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:ellipsize="end"
                        android:maxLines="1"
                        android:textColor="#4E4442"
                        android:textSize="12sp" />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>
</FrameLayout>
