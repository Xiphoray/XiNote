<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- Dynamically colored background with rounded corners -->
    <ImageView
        android:id="@+id/widget_background_view"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="fitXY"
        android:src="@drawable/widget_background" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Widget Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/widget_title"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="XiNote"
                android:textColor="#1F1B1A"
                android:textSize="16sp"
                android:textStyle="bold"
                android:fontFamily="serif"
                android:letterSpacing="0.02" />

            <ImageView
                android:id="@+id/btn_add_note"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:contentDescription="新增记事"
                android:padding="6dp"
                android:scaleType="fitCenter"
                android:src="@drawable/ic_add" />
        </LinearLayout>

        <!-- Main Divider under Header -->
        <FrameLayout
            android:id="@+id/widget_divider"
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="8dp"
            android:background="#E5DED8" />

        <!-- Empty State View -->
        <TextView
            android:id="@+id/widget_empty_text"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:text="暂无内容，点击上方 + 新增"
            android:textColor="#857370"
            android:textSize="13sp"
            android:fontFamily="serif"
            android:visibility="gone" />

        <!-- Notes List Container -->
        <ListView
            android:id="@+id/notes_list"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:divider="@null"
            android:dividerHeight="0dp"
            android:scrollbars="none" />
    </LinearLayout>
</FrameLayout>
